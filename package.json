{
  "name": "muslimos",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "qa:release": "npm run build && npm run test:e2e",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npm run build && npx cap sync android",
    "android:apk:debug": "npm run android:build && cd android && ./gradlew assembleDebug",
    "android:aab:release": "npm run android:build && cd android && ./gradlew bundleRelease",
    "screenshots": "node scripts/generate-screenshots.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.96",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.58.2",
    "vite": "^6.0.0"
  }
}
